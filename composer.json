{
  "name": "entelisteam/lbaf-mysql",
  "description": "A simple and quick mysqli wrapper for connecting to MySQL from PHP.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "mysql", "mysqli", "database", "mariadb"
  ],
  "authors": [
    {
      "name": "ENTELISTEAM INC",
      "email": "welcome@entelis.team",
      "homepage": "https://entelis.team"
    }
  ],
  "require": {
    "php": "~8.2",
    "entelisteam/lbaf-exception": "^1.0",
    "ext-mysqli": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "rector/rector": "^2.3.0"
  },
  "autoload": {
    "psr-4": {
      "EntelisTeam\\Lbaf\\MySql\\": "src/",
      "EntelisTeam\\Lbaf\\MySql\\Rector\\": "rector/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "EntelisTeam\\Lbaf\\MySql\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "minimum-stability": "dev"
}
